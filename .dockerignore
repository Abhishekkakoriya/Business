# ============================================
# DOCKER IGNORE - CAREER ACCELERATOR
# ============================================
# Exclude unnecessary files from Docker build context

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output
.next/
out/

# Development files
.git
.gitignore
README.md
*.md
!SETUP_GUIDE.md

# Environment files (will be provided at runtime)
.env*.local
.env.development

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test files
coverage
.nyc_output
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Logs
logs
*.log

# Temporary files
tmp
temp
*.tmp

# Docker files (no need to include in image)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
